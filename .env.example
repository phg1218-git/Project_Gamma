# ============================================
# 이어줌 (Connecting) — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to version control.

# ── Database (Neon PostgreSQL) ──────────────
# Get from: https://console.neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/earszoom?sslmode=require"

# Direct connection URL for Prisma migrations (bypasses connection pooler)
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/earszoom?sslmode=require"

# ── Auth.js (NextAuth) ─────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Your app URL (http://localhost:3000 for dev)
NEXTAUTH_URL="http://localhost:3000"

# ── Google OAuth ───────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Naver OAuth ────────────────────────────
# Get from: https://developers.naver.com/apps
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# ── Kakao OAuth ────────────────────────────
# Get from: https://developers.kakao.com/console/app
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# ── Admin Panel ────────────────────────────
# Admin login credentials
ADMIN_ID="admin"
ADMIN_PASSWORD="change-this-password"

# Admin JWT secret (generate with: openssl rand -base64 32)
ADMIN_JWT_SECRET="your-admin-jwt-secret-here"

# ── Firebase (Mobile Push) ─────────────────
# Firebase Console → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
# 다운로드한 JSON 파일 전체를 한 줄 문자열로 붙여넣기
# (미설정 시 푸시 발송 없이 앱 정상 동작)
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'

# ── Optional: Sentry ──────────────────────
# Get from: https://sentry.io
# SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""
